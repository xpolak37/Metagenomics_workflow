/*
========================================================================================
    METAGENOMIC PROFILING PIPELINE - Configuration File
========================================================================================
*/

/*
========================================================================================
    Cache Directories
========================================================================================
    These directories will store downloaded databases and container images.
    Set them to persistent, shared locations to avoid re-downloading.
    
    Recommended setup:
    - Use shared filesystem paths accessible to all compute nodes
    - Ensure sufficient storage (MetaPhlAn4 ~35GB, mOTUs ~7GB, containers ~3GB)
========================================================================================
*/

params {
    
    ////////////////////////////////////////////////////////////////////////////////////
    // Cache directories
    singularity_cache_dir     = './singularity_cache'  // Container images cache
    database_cache_dir        = './databases'          // Database cache (MetaPhlAn4)
    bowtie_phix_index = './bowtie_phix' // path to your bowtie indexes
    host_genome_index = './hostile_index' // path to pre-downloaded hostile human index

    ////////////////////////////////////////////////////////////////////////////////////
    // Input/Output options
    input                      = null
    outdir                     = './results'
    
    ////////////////////////////////////////////////////////////////////////////////////
    // Run parameters
    tax_level = "species"
    run_id = "run01"
    quick       = false
    quick_depth = 1000000
    metastandard_top_n = 10
    kraken_profiling = true

    ////////////////////////////////////////////////////////////////////////////////////
    // Fastp parameters - Quality Filtering
    fastp_qualified_quality_phred     = 15    // Q15 minimum quality
    fastp_unqualified_percent_limit   = 40    // 40% unqualified bases allowed
    fastp_n_base_limit                = 5     // Max N bases allowed
    fastp_average_qual                = 0     // Average quality threshold (0 = disabled)
    
    // Fastp parameters - Length Filtering
    fastp_length_required             = 15    // Minimum read length (default 15)
    fastp_length_limit                = 0     // Maximum read length (0 = no limit)
    
    // Fastp parameters - Adapter Trimming
    fastp_detect_adapter_for_pe       = true  // Auto-detect adapters for PE data
    fastp_adapter_sequence            = null  // Manual adapter for read1 (auto if null)
    fastp_adapter_sequence_r2         = null  // Manual adapter for read2 (auto if null)
    
    // Fastp parameters - Fixed Trimming
    fastp_trim_front1                 = 0     // Trim N bases from read1 5' end
    fastp_trim_tail1                  = 0     // Trim N bases from read1 3' end
    fastp_trim_front2                 = 0     // Trim N bases from read2 5' end
    fastp_trim_tail2                  = 0     // Trim N bases from read2 3' end
    
    // Fastp parameters - Sliding Window Quality Trimming
    fastp_cut_front                   = false // Enable cut_front (5' to 3' sliding window)
    fastp_cut_tail                    = false // Enable cut_tail (3' to 5' sliding window)
    fastp_cut_right                   = false // Enable cut_right (aggressive 5' to 3')
    fastp_cut_window_size             = 4     // Sliding window size
    fastp_cut_mean_quality            = 20    // Mean quality threshold for sliding window (Q20)
    
    // Fastp parameters - PolyG/PolyX Trimming
    fastp_trim_poly_g                 = false // Force polyG trimming (auto for NextSeq/NovaSeq)
    fastp_disable_trim_poly_g         = false // Disable automatic polyG trimming
    fastp_trim_poly_x                 = false // Enable polyX trimming
    
    // Fastp parameters - Other Options
    fastp_dedup                       = false // Enable deduplication
    fastp_low_complexity_filter       = false // Enable complexity filter
    fastp_complexity_threshold        = 30    // Complexity threshold (30%)
    fastp_correction                  = false // Enable base correction in overlaps
    fastp_compression                 = 4     // Compression level (1-9, default 4)
    fastp_extra_args                  = ''    // Additional arguments
    
    // Hostile
    host_decontamination = true

    ////////////////////////////////////////////////////////////////////////////////////
    // MetaPhlAn4 parameters
    // MetaPhlAn4 parameters - Database
    metaphlan_db                      = "${params.database_cache_dir}/metaphlan4/metaphlan_db"  // Path to MetaPhlAn database (relative to database_cache_dir)
    metaphlan_index                   = 'latest'  // Database version: 'latest' or specific version like 'mpa_vJan21_CHOCOPhlAnSGB_202103'
    metaphlan_offline                 = false // Don't check for database updates
    
    // MetaPhlAn4 parameters - Mapping (Bowtie2)
    metaphlan_bt2_ps                  = 'very-sensitive'  // Bowtie2 preset: sensitive, very-sensitive, sensitive-local, very-sensitive-local
    metaphlan_min_mapq_val            = 5     // Minimum mapping quality (MAPQ)
    metaphlan_read_min_len            = 70    // Minimum read length to consider
    metaphlan_save_mapout             = false // Save mapping output file (can be large)
    
    // MetaPhlAn4 parameters - Taxonomic Level
    metaphlan_tax_level               = 'a'  // a=all, k=kingdom, p=phylum, c=class, o=order, f=family, g=genus, s=species, t=SGBs
    
    // MetaPhlAn4 parameters - Taxonomic Filtering
    metaphlan_ignore_eukaryotes       = false // Exclude eukaryotic organisms
    metaphlan_ignore_bacteria         = false // Exclude bacterial organisms
    metaphlan_ignore_archaea          = false // Exclude archaeal organisms
    
    // MetaPhlAn4 parameters - Post-mapping
    metaphlan_min_alignment_len       = null  // Minimum alignment length (null = auto)
    metaphlan_stat_q                  = 0.2   // Quantile for robust average
    metaphlan_perc_nonzero            = 0.33  // Percentage of markers for species identification
    metaphlan_stat                    = 'tavg_g'  // Statistical method: avg_g, avg_l, tavg_g, tavg_l, wavg_g, wavg_l, med
    metaphlan_ignore_markers          = null  // File with markers to ignore
    
    // MetaPhlAn4 parameters - Analysis Type
    metaphlan_analysis_type           = 'rel_ab_w_read_stats'  // rel_ab, rel_ab_w_read_stats, clade_profiles, marker_ab_table, marker_pres_table
    metaphlan_strain                  = false
    strainphlan_sgb                   = null
    strainphlan_sample_with_n_markers = 10
    strainphlan_sample_with_n_markers_perc = 10
    // MetaPhlAn4 parameters - Other
    metaphlan_verbose                 = false // Verbose output
    metaphlan_extra_args              = ''    // Additional arguments
    
    ////////////////////////////////////////////////////////////////////////////////////
    // Mock community evaluation parameters
    mock_evaluation                   = true  // Enable/disable mock evaluation
    mock_pattern                      = 'Mock\\d+'  // Regex to identify mock samples
    mock_abundance                    = './composition/mock_asv_abundance.csv'  // Reference abundances
    mock_taxa                         = './composition/mock_taxa.csv'  // Reference taxonomy
    mock_top_n                        = 15  // Number of top genera to display in barplot
    mock_synonyms                     = "${projectDir}/composition/genus_synonyms.csv"  // Genus synonym dictionary for mock evaluation
    
    ////////////////////////////////////////////////////////////////////////////////////
    // MultiQC parameters
    multiqc_config                    = null
    multiqc_title                     = 'Metagenomic Profiling Report'
    multiqc_extra_args                = ''
    
    ////////////////////////////////////////////////////////////////////////////////////
    // Resource allocation defaults (can be overridden per process)
    max_cpus                          = 16
    max_memory                        = '128.GB'
    max_time                          = '48.h'
}

/*
========================================================================================
    Singularity configuration
========================================================================================
*/

singularity {
    enabled = true
    autoMounts = true
    cacheDir = params.singularity_cache_dir
    envWhitelist = 'SINGULARITY_TMPDIR'
}

env {
    SINGULARITY_TMPDIR = '.'
    TMPDIR             = '.'
}

/*
========================================================================================
    Process-specific resource requirements
========================================================================================
*/

process {
    
    // Global container settings
    container = null
    
    // Error strategy
    errorStrategy = 'terminate'
    
    // FastQC raw
    withName: 'FASTQC_RAW' {
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
    }
    
    // Fastp
    withName: 'FASTP' {
        cpus = 8
        memory = 16.GB
        time = 4.h
        container = 'docker://quay.io/biocontainers/fastp:0.23.4--hadf994f_3'
    }
    
    // FastQC clean
    withName: 'FASTQC_CLEAN' {
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
    }
    
    // MetaPhlAn4 database download
    withName: 'METAPHLAN4_DB' {
        cpus = 4
        memory = 8.GB
        time = 4.h
        container = 'docker://quay.io/biocontainers/metaphlan:4.2.4--pyhdfd78af_0'
    }
    
     withName: 'HOST_REMOVAL'{
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bowtie2:2.5.5--ha27dd3b_0'
    }

    withName: 'PHIX_REMOVAL'{
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/bowtie2:2.5.5--ha27dd3b_0'
    }
    
    withName: 'FASTQ_SYNC'{
        cpus = 4
        memory = 8.GB
        time = 2.h
        container = 'docker://quay.io/biocontainers/fastp:1.3.3--h43da1c4_0'
    }

    // MetaPhlAn4
    withName: 'METAPHLAN4' {
        cpus = 48
        memory = 48.GB
        time = 8.h
        container = 'docker://quay.io/biocontainers/metaphlan:4.2.4--pyhdfd78af_0'
    }
    withName: 'KRAKEN2' {
        cpus = 48
        memory = 48.GB
        time = 8.h
        container = 'docker://quay.io/biocontainers/kraken2:2.17.1--pl5321h077b44d_0'
    }
    
    withName: 'BRACKEN' {
        cpus = 48
        memory = 48.GB
        time = 8.h
        container = 'docker://quay.io/biocontainers/bracken:3.1--h9948957_0'
    }

    // EXTRACT_MARKERS
    withName: 'EXTRACT_MARKERS' {
        cpus = 8
        memory = 16.GB
        time = 8.h
        container = 'docker://quay.io/biocontainers/metaphlan:4.2.4--pyhdfd78af_0'
    }
    
    // STRAINPHLAN
    withName: 'STRAINPHLAN' {
        cpus = 8
        memory = 16.GB
        time = 8.h
        container = 'docker://quay.io/biocontainers/metaphlan:4.2.4--pyhdfd78af_0'
    }
    
    // STRAINPHLAN
    withName: 'SAMPLE2MARKERS' {
        cpus = 8
        memory = 16.GB
        time = 8.h
        container = 'docker://quay.io/biocontainers/metaphlan:4.2.4--pyhdfd78af_0'
    }

    // METASTANDARD
    withName: 'METASTANDARD' {
        cpus = 4
        memory = 8.GB
        time = 4.h
        container = 'docker://quay.io/biocontainers/pandas:2.2.1'
    }

    // MetaStandard plots
    withName: 'METASTANDARD_PLOTS' {
        cpus = 2
        memory = 4.GB
        time = 1.h
        container = 'docker://quay.io/biocontainers/seaborn:0.13.2'
    }
    
    // MultiQC
    withName: 'MULTIQC' {
        cpus = 2
        memory = 4.GB
        time = 1.h
        container = 'docker://quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0'
    }
}

/*
========================================================================================
    Execution profiles
========================================================================================
*/

profiles {
    
    standard {
        process.executor = 'local'
    }
    
    slurm {
        process {
            executor = 'slurm'
            queue = 'default'
            clusterOptions = null
        }
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }
 
    test {
        params.max_cpus = 2
        params.max_memory = 6.GB
        params.max_time = 1.h
    }

}

/*
/*
========================================================================================
    Report and trace options
========================================================================================
*/

timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_info/dag.svg"
}

manifest {
    name = 'metagenomic-profiling-pipeline'
    author = 'Alise Ponsero'
    description = 'Nextflow pipeline for metagenomic profiling benchmark with Fastp, FastQC, MetaPhlAn4, and mOTUs'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version = '1.0.0'
}
